# Normalize line endings across platforms — text files use LF in the repo.
* text=auto eol=lf

# Windows-native scripts keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary assets — never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ttf  binary
*.otf  binary
*.ico  binary
*.jar  binary
*.keystore binary
*.jks  binary
